{
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "uri": {
      "type": "string"
    },
    "guid": {
      "type": "string",
      "format": "uuid"
    },
    "seoDescription": {
      "type": "string"
    },
    "sidebarVideo": {
      "type": "string"
    },
    "thumbnail": {
      "type": "string"
    },
    "created": {
      "type": "string",
      "format": "date-time"
    },
    "createdBy": {
      "type": "string"
    },
    "createdByEmail": {
      "type": "string"
    },
    "lastUpdated": {
      "type": "string",
      "format": "date-time"
    },
    "lastUpdatedBy": {
      "type": "string"
    },
    "lastUpdatedByEmail": {
      "type": "string"
    },
    "isArchived": {
      "type": "boolean"
    },
    "archivedreason": {
      "type": ["string", "null"]
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "category": {
            "type": "string"
          }
        },
        "required": ["category"]
      }
    },
    "authors": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          }
        },
        "required": ["title", "url"]
      }
    },
    "related": {
      "type": ["array", "null"],
      "items": {
        "type": "object",
        "properties": {
          "rule": {
            "type": "string"
          }
        },
        "required": ["rule"]
      }
    },
    "redirects": {
      "type": ["array", "null"],
      "items": {
        "type": "string"
      }
    }
  },
  "required": ["title", "guid", "uri", "seoDescription", "authors"],
  "additionalProperties": true,
  "errorMessage": {
    "properties": {
      "title": "'title' cannot be empty.",
      "guid": "'guid' must be a valid GUID.",
      "uri": "'uri' must not be empty.",
      "seoDescription": "'seoDescription' cannot be empty.",
      "authors": "'authors' must be valid content with 'title' and 'url' for each entry.",
      "related": "'related' must be a list of objects each with a 'rule' file path.",
      "categories": "'categories' must be a list of objects each with a 'category' file path.",
      "archivedreason": "'archivedreason' must be a string or null."
    }
  }
}
