{
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "top-category"
    },
    "title": {
      "type": "string"
    },
    "uri": {
      "type": "string"
    },
    "index": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "category": {
            "type": "string"
          }
        },
        "required": ["category"]
      }
    },
    "lastUpdated": {
      "type": "string",
      "format": "date-time"
    },
    "lastUpdatedBy": {
      "type": "string"
    },
    "lastUpdatedByEmail": {
      "type": "string"
    },
    "isArchived": {
      "type": "boolean"
    },
    "archivedreason": {
      "type": ["string", "null"]
    }
  },
  "required": ["type", "title", "index", "uri"],
  "additionalProperties": true,
  "errorMessage": {
    "properties": {
      "type": "'type' must be set to 'top-category'.",
      "title": "'title' cannot be empty.",
      "uri": "'uri' must not be empty.",
      "index": "'index' must be a list of objects each with a 'category' file path."
    }
  }
}
